{
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features",
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features",
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[less]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[markdown]": {
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.wordWrap": "on",
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[sql]": {
    "editor.defaultFormatter": "inferrinizzard.prettier-sql-vscode",
  },
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
  },
  "accessibility.signals.lineHasFoldedArea": {
    "sound": "on",
  },
  "advancedNewFile.exclude": {
    "android": true,
    "assets": true,
    "build": true,
    "coverage": true,
    "dev": true,
    "dist": true,
    "ios": true,
    "node_modules": true,
    "node_modules_electron": true,
  },
  "chat.commandCenter.enabled": false,
  "easynpm.packageManager": "yarn",
  "editor.accessibilitySupport": "off",
  "editor.bracketPairColorization.enabled": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit",
  },
  "editor.cursorSurroundingLines": 8,
  "editor.fontFamily": "Fira Code",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.formatOnSave": true,
  "editor.guides.bracketPairs": "active",
  "editor.inlineSuggest.enabled": true,
  "editor.lineNumbers": "relative",
  "editor.minimap.enabled": false,
  "editor.renderControlCharacters": false,
  "editor.renderWhitespace": "trailing",
  "editor.suggestSelection": "first",
  "editor.tokenColorCustomizations": {
    "functions": "#20A1ED",
    "keywords": "#f71717",
    "strings": "#14ca14",
    "variables": "#0a9e74",
  },
  "editor.unicodeHighlight.allowedCharacters": {
    "‪": true,
  },
  "errorLens.excludeBySource": ["ts(2554)"],
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "workbench.list.automaticKeyboardNavigation": false,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.cts": "${capture}.typegen.ts",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.mts": "${capture}.typegen.ts",
    "*.ts": "${capture}.js, ${capture}.typegen.ts",
    "*.tsx": "${capture}.ts, ${capture}.typegen.ts",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml",
    "tsconfig.json": "tsconfig.*.json",
  },
  "files.associations": {
    "*.ts": "typescript",
    ".env": "env",
  },
  "files.autoSaveDelay": 20000000,
  "files.exclude": {
    "**/.classpath": true,
    "**/.factorypath": true,
    "**/.git": true,
    "**/.project": true,
    "**/.settings": true,
  },
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.ignoreRebaseWarning": true,
  "git.mergeEditor": true,
  "git.suggestSmartCommit": false,
  "gitlens.rebaseEditor.ordering": "asc",
  "gitlens.views.branches.branches.layout": "list",
  "gitlens.views.stashes.files.layout": "tree",
  "hediet.vscode-drawio.resizeImages": null,
  "i18n-ally.enabledFrameworks": ["react"],
  "i18n-ally.extract.keyMaxLength": 120,
  "i18n-ally.sortKeys": true,
  "i18n-ally.translate.engines": ["google", "deepl"],
  "javascript.format.semicolons": "remove",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "json.schemas": [],
  "mergeEditor.diffAlgorithm": "legacy",
  "security.promptForLocalFileProtocolHandling": false,
  "security.workspace.trust.untrustedFiles": "open",
  "terminal.integrated.env.osx": {
    "CW_NEW_SESSION": "1",
    "FIG_NEW_SESSION": "1",
    "Q_NEW_SESSION": "1",
  },
  "terminal.integrated.fontFamily": "monospace",
  "terminal.integrated.tabs.location": "left",
  "typescript.format.semicolons": "remove",
  "typescript.updateImportsOnFileMove.enabled": "always",
  "vim.easymotion": true,
  "vim.incsearch": true,
  "vim.insertModeKeyBindings": [
    {
      "after": ["<Esc>"],
      "before": ["j", "j"],
    },
  ],
  "vim.leader": "<space>",
  "vim.normalModeKeyBindingsNonRecursive": [],
  "vim.useSystemClipboard": true,
  "vsicons.dontShowNewVersionMessage": true,
  "window.customTitleBarVisibility": "auto",
  "workbench.activityBar.location": "bottom",
  "workbench.colorTheme": "Catppuccin Macchiato",
  "workbench.editor.enablePreview": false,
  "workbench.editor.revealIfOpen": true,
  "workbench.editorAssociations": {
    "*.ts": "default",
  },
  "workbench.iconTheme": "vscode-icons",
  "workbench.sideBar.location": "right",
  "workbench.startupEditor": "none",
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "chat.showAgentSessionsViewDescription": false,
  "terminal.integrated.sendKeybindingsToShell": true,
  "python.defaultInterpreterPath": "/opt/homebrew/bin/python3",
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "kilo-code.debug": false,
  "kilo-code.allowedCommands": ["git log", "git diff", "git show"],
  "kilo-code.deniedCommands": [],
  "diffEditor.ignoreTrimWhitespace": true,
  "diffEditor.useInlineViewWhenSpaceIsLimited": false,
  "diffEditor.experimental.showMoves": true,
  "[vue]": {
    "editor.defaultFormatter": "Vue.volar"
  },
  "update.releaseTrack": "dev",
}
