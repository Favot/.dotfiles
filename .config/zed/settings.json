// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
//
// SECURITY NOTE: Do NOT add API keys or secrets directly in this file.
// Use environment variables instead: "api_key": "${env.MINIMAX_API_KEY}"
{
  "agent_servers": {
    "opencode": {
      "type": "registry",
    },
  },
  "edit_predictions": {
    "provider": "open_ai_compatible_api",
    "open_ai_compatible_api": {
      "api_url": "https://api.minimax.io/v1/completions",
      "model": "MiniMax-M2.7",
      "prompt_format": "infer",
      "max_output_tokens": 64,
    },
  },
  "language_models": {
    "openai_compatible": {
      "MiniMax": {
        "api_url": "\thttps://api.minimax.io/v1",
        "available_models": [
          {
            "name": "MiniMax-M2.7",
            "max_tokens": 200000,
            "max_output_tokens": 32000,
            "max_completion_tokens": 200000,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": false,
              "prompt_cache_key": false,
              "chat_completions": true,
            },
          },
        ],
      },
    },
  },
  "agent": {
    "profiles": {},
    "default_model": {
      "provider": "MiniMax",
      "model": "MiniMax-M2.7",
    },
    "model_parameters": [],
  },
  "project_panel": {
    "indent_size": 12.0,
    "git_status": true,
    "folder_icons": true,
    "file_icons": true,
    "entry_spacing": "standard",
    "default_width": 320.0,
    "dock": "right",
  },
  "vim_mode": true,
  "terminal": {
    "env": {
      "Q_NEW_SESSION": "\"1\"",
      "FIG_NEW_SESSION": "\"1\"",
      "CW_NEW_SESSION": "\"1\"",
    },
    "font_family": "monospace",
  },
  "base_keymap": "VSCode",
  "preview_tabs": {
    "enabled": false,
  },
  "relative_line_numbers": "enabled",
  "vertical_scroll_margin": 8.0,
  "gutter": {
    "line_numbers": true,
  },
  "minimap": {
    "show": "never",
  },
  "buffer_font_family": "Fira Code",
  "file_types": {
    "typescript": ["*.ts"],
    "env": [".env"],
  },
  "colorize_brackets": true,
  "show_whitespaces": "trailing",
  "show_edit_predictions": true,
  "ui_font_size": 16,
  "buffer_font_size": 14.0,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
}
